# Vercel Ignore File
# Exclude backend-heavy directories to stay under the 250MB limit

# Backend Source (Root only)
/config/
/models/
/data/
/reports/
/logs/
/monitoring/

# Allow frontend
!frontend/

# Python Virtual Env (Just in case)
.venv/
venv/
__pycache__/
*.pyc

# Deployment & Docker
deploy/
docker-compose.yml
Dockerfile
Dockerfile.*
render.yaml
/requirements.txt

# Database
*.db
*.sqlite
supabase_schema.sql

# Git
.git/
.dvc/
